{
    "name": "decoda/nfe-core-client",
    "description": "Biblioteca base para integracao com NFS-e Padrao Nacional (SEFIN Nacional).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "autoload": {
        "psr-4": {
            "Nfse\\Core\\": "src/",
            "Config\\": "src/Config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nfse\\Core\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit"
    },
    "suggest": {
        "codeigniter4/framework": "Necessario para usar os adapters de Config e Services do CI4."
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
